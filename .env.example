# Database Configuration (from parent project)
DATABASE_URL=postgresql://username:password@host:port/database

# OpenAI Configuration (from parent project)

# LLM_MODEL=gpt-4-turbo-preview

# Object Storage Configuration (MinIO from parent project - S3 compatible)
STORAGE_TYPE=minio
MINIO_ENDPOINT=your-minio-endpoint.example.com
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET_NAME=your-bucket-name
MINIO_PUBLIC_ENDPOINT=https://your-public-endpoint.example.com

# AWS S3 Configuration (alternative to MinIO)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=social-scene-images

# Stable Diffusion Configuration
# Option 1: Local deployment
STABLE_DIFFUSION_URL=http://localhost:7860

# Option 2: Replicate API
REPLICATE_API_TOKEN=your-replicate-token

# Option 3: HuggingFace API
HUGGINGFACE_API_TOKEN=your-hf-token

# Image Generation Provider (local|replicate|huggingface)
IMAGE_PROVIDER=local

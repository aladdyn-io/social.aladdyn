generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  schemas    = ["social"]
}

// ── Social Campaigns ─────────────────────────────────────────────────────────
// Each campaign belongs to a Funnel (from server.aladdyn).
// funnelId and userId are cross-service references — not enforced by Prisma FK.

model SocialCampaign {
  id     String @id @default(uuid())
  // Cross-service references to server.aladdyn
  funnelId String // FK → funnels.id in server.aladdyn
  userId   String // FK → users.id in server.aladdyn

  // Campaign identity
  name String?

  // Schedule
  startDate        DateTime
  endDate          DateTime
  timezone         String   @default("Asia/Kolkata")
  totalDays        Int
  frequencyPerWeek Int

  // Platform & content requirements (from activation form)
  platforms   String[] // ["instagram", "linkedin"]
  contentMix  Json     // { photo: 4, reel: 2, carousel: 2, story: 1, written: 2 }
  postingTimes Json?   // { instagram: ["09:00", "18:00"], linkedin: ["10:00"] }

  // Brand context — snapshot from funnel at activation time
  industry    String?
  geography   String?
  companyName String?
  companyDesc String?  @db.Text
  websiteUrl  String?
  tone        String?
  brandLogo   String?
  brandColor  String?
  accentColor String?
  services    String[]

  // Instagram credentials (set at campaign creation from connected account)
  igUserId    String? // IG Business/Creator account ID
  accessToken String? @db.Text // long-lived user access token (store encrypted at rest)

  // OAuth-connected social account (optional — overrides igUserId/accessToken when set)
  socialAccountId String?
  socialAccount   SocialAccount? @relation(fields: [socialAccountId], references: [id])

  // AI options
  festivalEnabled Boolean      @default(true)
  goal            CampaignGoal @default(AWARENESS)

  // Lifecycle
  status    CampaignStatus @default(DRAFT)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  strategy SocialStrategy?
  posts    SocialPost[]
  pipelineRun PipelineRun?
  tokenLedger CampaignTokenLedger?

  @@index([funnelId])
  @@index([userId])
  @@index([status])
  @@index([socialAccountId])
  @@map("social_campaigns")
  @@schema("social")
}

enum CampaignGoal {
  AWARENESS
  CONSIDERATION
  CONVERSION
  RETENTION

  @@schema("social")
}

// ── OAuth-Connected Social Accounts ──────────────────────────────────────────
// One row per platform account per user. Created/updated via OAuth callback.
// Tokens are stored AES-256-GCM encrypted; decryption happens at publish time.

enum SocialAccountPlatform {
  LINKEDIN
  INSTAGRAM

  @@schema("social")
}

model SocialAccount {
  id        String                @id @default(uuid())
  userId    String                // FK → users.id in server.aladdyn (cross-service)
  platform  SocialAccountPlatform

  // Platform-specific identifiers
  platformAccountId String  // IG Business Account ID  OR  LinkedIn member sub (from /v2/userinfo)
  authorUrn         String? // LinkedIn posting URN: "urn:li:person:xxx" or "urn:li:organization:xxx"
  accountName       String  // Display name shown in UI
  accountHandle     String? // @username or LinkedIn vanity URL
  profilePictureUrl String?

  // Encrypted OAuth credentials
  // Values are AES-256-GCM encrypted via oauthService.encryptToken()
  accessToken      String  @db.Text
  refreshToken     String? @db.Text // LinkedIn only (60-day refresh)
  tokenExpiresAt   DateTime? // null = indefinitely long-lived (Meta Page tokens)

  // Extra platform metadata (e.g. { pageId, pageName } for IG-linked FB pages)
  metadata Json?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Campaigns linked to this connected account
  campaigns SocialCampaign[]

  @@unique([userId, platform, platformAccountId])
  @@index([userId, platform])
  @@index([isActive])
  @@map("social_accounts")
  @@schema("social")
}

enum CampaignStatus {
  DRAFT
  GENERATING
  READY
  ACTIVE
  PAUSED
  COMPLETED
  FAILED

  @@schema("social")
}

// ── Social Strategy ──────────────────────────────────────────────────────────
model SocialStrategy {
  id         String @id @default(uuid())
  campaignId String @unique

  contentPillars String[]
  tone           String?
  ctaStyle       String?
  contentMix     Json     // { education: 30, trust: 50, promotion: 20 }
  hashtagGroups  Json?
  campaignPhases Json?
  modelUsed      String?

  createdAt DateTime @default(now())

  campaign SocialCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("social_strategies")
  @@schema("social")
}

// ── Social Posts ─────────────────────────────────────────────────────────────
model SocialPost {
  id         String @id @default(uuid())
  campaignId String

  // Schedule
  scheduledDate DateTime
  scheduledTime String   @default("10:00") // HH:mm
  timezone      String   @default("Asia/Kolkata")

  // Target
  platform    String // "instagram" | "linkedin"
  contentType String // "photo" | "reel" | "carousel" | "story" | "written"

  // Content
  caption     String?  @db.Text
  hashtags    String[]
  callToAction String?

  // Image lifecycle
  imagePrompt    String? @db.Text // detailed prompt for AI generation
  imageUrl       String? // MinIO URL after generation
  imageGenerated Boolean @default(false)
  imageModel     String?

  // Video lifecycle
  videoPrompt  String?  @map("video_prompt") @db.Text
  mediaType    String   @map("media_type") @default("image")
  isFallback   Boolean  @map("is_fallback") @default(false)

  // Metadata
  contentPillar String?
  topic         String?
  isFestival    Boolean @default(false)
  festivalName  String?

  // Publish lifecycle
  status         PostStatus @default(DRAFT)
  approvedAt     DateTime?
  publishedAt    DateTime?
  platformPostId String?    // ID returned by Meta/LinkedIn after publish
  publishError   String?    @db.Text
  publishAttempts Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaign     SocialCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  publishLogs  PostPublishLog[]
  engagements  SocialEngagement[]

  @@index([campaignId, scheduledDate])
  @@index([status, scheduledDate])
  @@index([platform, status])
  @@map("social_posts")
  @@schema("social")
}

// ── Publish Attempt Log ───────────────────────────────────────────────────────
// Full history of every publish attempt per post (success + failure).
// Replaces the single publishError field as the audit trail.
model PostPublishLog {
  id         String  @id @default(uuid())
  postId     String
  campaignId String
  platform   String
  attempt    Int
  status     String  // "succeeded" | "failed"
  error      String? @db.Text
  jobId      String? // BullMQ job ID

  post SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([postId])
  @@index([campaignId, createdAt])
  @@map("post_publish_logs")
  @@schema("social")
}

enum PostStatus {
  DRAFT
  APPROVED
  SCHEDULED
  PUBLISHING
  POSTED
  FAILED
  DELETED
  REJECTED

  @@schema("social")
}

// ── Post Engagement Tracking ──────────────────────────────────────────────────
model SocialEngagement {
  id             String    @id @default(uuid())
  postId         String
  post           SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform       String    // "instagram" | "linkedin"
  externalUserId String
  displayName    String?
  engagementType String    // "LIKE" | "COMMENT"
  content        String?   @db.Text // comment text
  engagedAt      DateTime  @default(now())
  leadSignalSentAt DateTime? // timestamp when emitted to server.aladdyn

  @@unique([postId, externalUserId, engagementType])
  @@index([postId])
  @@index([leadSignalSentAt])
  @@map("social_engagements")
  @@schema("social")
}

// ── Upgraded Pipeline State Tracking ──────────────────────────────────────────

model PipelineRun {
  id            String               @id @default(uuid())
  campaignId    String               @unique
  campaign      SocialCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  status        PipelineStatus       @default(PENDING)
  brandInput    Json
  createdAt     DateTime             @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  stages        PipelineStageOutput[]

  @@map("pipeline_runs")
  @@schema("social")
}

model PipelineStageOutput {
  id            String         @id @default(uuid())
  runId         String
  pipelineRun   PipelineRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  stageName     String
  status        StageStatus    @default(PENDING)
  outputJson    Json?
  errorMessage  String?        @db.Text
  attemptCount  Int            @default(0)
  completedAt   DateTime?

  @@unique([runId, stageName])
  @@map("pipeline_stage_outputs")
  @@schema("social")
}

enum PipelineStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  FAILED

  @@schema("social")
}

enum StageStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  OVERRIDDEN

  @@schema("social")
}

// ── Regeneration Token System ─────────────────────────────────────────────────

model CampaignTokenLedger {
  id         String   @id @default(uuid())
  campaignId String   @unique @map("campaign_id")
  balance    Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  campaign     SocialCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  transactions CampaignTokenTransaction[]

  @@map("campaign_token_ledgers")
  @@schema("social")
}

model CampaignTokenTransaction {
  id           String   @id @default(uuid())
  campaignId   String   @map("campaign_id")
  ledgerId     String   @map("ledger_id")
  type         String
  amount       Int
  balanceAfter Int      @map("balance_after")
  description  String
  postId       String?  @map("post_id")
  createdAt    DateTime @default(now()) @map("created_at")

  ledger CampaignTokenLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@map("campaign_token_transactions")
  @@schema("social")
}
